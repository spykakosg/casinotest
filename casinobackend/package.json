{
  "name": "casino-backend",
  "version": "1.0.0",
  "description": "Crypto Casino Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand",
    "watcher": "node src/services/depositWatcher.js",
    "gen-addresses": "node src/services/addressGenerator.js",
    "db:migrate": "node -e \"require('dotenv').config(); const {execSync}=require('child_process'); execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/schema.sql', {stdio:'inherit'})\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
